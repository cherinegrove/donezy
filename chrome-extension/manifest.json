{
  "manifest_version": 3,
  "name": "Donezy Task & Timer",
  "version": "1.0",
  "description": "Create tasks and start timers for your Donezy workspace",
  "permissions": [
    "activeTab",
    "storage",
    "identity",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://puwxkygdlclcbyxrtppd.supabase.co/*",
    "https://app.donezy.io/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Donezy"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}